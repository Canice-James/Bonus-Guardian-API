{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Make alias resolve from src at compile time
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },

    // Environment
    "module": "CommonJS",
    "target": "ES2021",
    "lib": ["ES2021"],
    "types": ["node"],

    // Module resolution (TS >=4.7+)
    "moduleResolution": "node",

    // Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,

    // Interop
    "esModuleInterop": true,
    "resolveJsonModule": true,

    // Performance
    "skipLibCheck": true,
    "isolatedModules": true,

    // Disable strict null checks (disables "Object is possibly 'undefined'")
    "strictNullChecks": false,

    // Allow implicit 'any' types
    "noImplicitAny": false,

    // Allow 'unknown' types without explicit handling
    "noImplicitReturns": false
  }
}